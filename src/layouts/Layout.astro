---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Psicoterapia Transpessoal Sistêmica para quem busca equilíbrio emocional, autoconhecimento e expansão da consciência." } = Astro.props;
---

<!doctype html>
<html lang="pt-BR" class="scroll-smooth">
  <head>
    <!-- Configurações Google Meu Negócio (Site Verification) -->
    <!-- <meta name="google-site-verification" content="COLE_SEU_CODIGO_AQUI" /> -->

    <!-- Google Tag Manager -->
    <!-- Descomente e substitua 'GTM-XXXXXXX' pelo seu ID -->
    <!-- <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-XXXXXXX');</script> -->
    <!-- End Google Tag Manager -->

    <!-- Google Analytics (gtag.js) -->
    <!-- Descomente e substitua 'G-XXXXXXXXXX' pelo seu ID -->
    <!-- <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-XXXXXXXXXX');
    </script> -->

    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Local SEO & Keywords Estratégicas -->
    <meta name="keywords" content="psicóloga lauro de freitas, psicanalista lauro de freitas, psicoterapia lauro de freitas, terapia presencial lauro de freitas, psicóloga vilas do atlântico, terapia para ansiedade lauro de freitas, tratamento para depressão lauro de freitas, psicoterapeuta transpessoal sistêmica, psicanálise lauro de freitas, terapia online, ajuda psicológica lauro de freitas, saúde mental lauro de freitas, clínica de psicologia vilas do atlântico, erika spinola psicanalista, terapia sistêmica lauro de freitas, especialista em ansiedade bahia, autoconhecimento, terapia de casal lauro de freitas, psicóloga unimed lauro de freitas" />
    <meta name="geo.region" content="BR-BA" />
    <meta name="geo.placename" content="Lauro de Freitas" />
    <meta name="geo.position" content="-12.8943;-38.3275" />
    <meta name="ICBM" content="-12.8943, -38.3275" />

    <!-- Open Graph / Social SEO -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="pt_BR" />

    <title>{title}</title>

    <!-- Schema.org - LocalBusiness -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "PsychologicalService",
        "name": "Érika Spinola - Psicoterapia Transpessoal Sistêmica",
        "image": "/professional/logo.svg",
        "description": "Atendimento psicoterapêutico especializado em Lauro de Freitas, Bahia. Psicoterapia Transpessoal Sistêmica presencial e online.",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Consulte o endereço para atendimento presencial",
          "addressLocality": "Lauro de Freitas",
          "addressRegion": "BA",
          "postalCode": "42700-000",
          "addressCountry": "BR"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": -12.8943,
          "longitude": -38.3275
        },
        "url": "https://www.erikaspinola.com.br",
        "telephone": "+5571991951882",
        "priceRange": "$$",
        "openingHoursSpecification": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": [
            "Monday",
            "Tuesday",
            "Wednesday",
            "Thursday",
            "Friday"
          ],
          "opens": "08:00",
          "closes": "20:00"
        }
      }
    </script>
  </head>
  <body class="bg-brand-light text-brand-dark min-h-screen flex flex-col font-sans">
    <!-- Google Tag Manager (noscript) -->
    <!-- Descomente e substitua 'GTM-XXXXXXX' pelo seu ID -->
    <!-- <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-XXXXXXX"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript> -->
    <!-- End Google Tag Manager (noscript) -->
    <Header />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer />
  </body>
</html>
