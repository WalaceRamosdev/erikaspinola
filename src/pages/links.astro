---
import Layout from '../layouts/Layout.astro';

// SEO details
const title = "Erika Spinola | Psicanálise & Bem-estar";
const description = "Psicoterapeuta Transpessoal Sistêmica. Acesse canais de atendimento e mergulhe em uma jornada de autoconhecimento.";
---

<!DOCTYPE html>
<html lang="pt-BR" class="scroll-smooth">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <style>
        :root {
            --brand-green: #1F3A2E;
            --brand-dark: #11221B;
            --brand-gold: #C9A96A;
            --brand-gold-light: rgba(201, 169, 106, 0.2);
            --brand-white: #F8F8F8;
            --brand-light: #F0EFEA;
            --glass-bg: rgba(255, 255, 255, 0.4);
            --glass-border: rgba(255, 255, 255, 0.5);
        }

        html, body {
            margin: 0;
            padding: 0;
            width: 100%;
            overflow-x: hidden;
            background-color: var(--brand-light);
        }

        body {
            font-family: 'Inter', sans-serif;
            color: var(--brand-dark);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            position: relative;
        }

        .main-wrapper {
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            overflow-x: hidden;
            position: relative;
        }

        /* Animated Background Elements - Restored for Light BG */
        .background-blobs {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            overflow: hidden;
            pointer-events: none;
        }

        .blob {
            position: absolute;
            width: 400px;
            height: 400px;
            border-radius: 50%;
            filter: blur(80px);
            animation: move 25s infinite alternate ease-in-out;
            opacity: 0.3;
        }

        .blob-1 { top: -10%; left: -10%; background: radial-gradient(circle, rgba(31, 58, 46, 0.15) 0%, transparent 70%); }
        .blob-2 { bottom: -10%; right: -5%; background: radial-gradient(circle, rgba(201, 169, 106, 0.15) 0%, transparent 70%); animation-delay: -7s; }
        .blob-3 { top: 30%; left: 50%; width: 400px; height: 400px; background: radial-gradient(circle, rgba(201, 169, 106, 0.1) 0%, transparent 70%); animation-duration: 30s; }

        @keyframes move {
            0% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(30px, 40px) scale(1.05); }
            100% { transform: translate(-20px, 20px) scale(0.95); }
        }

        .noise-texture {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            opacity: 0.05;
            pointer-events: none;
            background-image: 
                radial-gradient(circle at 2px 2px, rgba(255,255,255,0.05) 1px, transparent 0),
                url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3BaseFilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
            background-size: 40px 40px, auto;
        }

        /* Particles - Custom leaf/petal feel in CSS */
        .particle {
            position: absolute;
            top: -20px;
            background: var(--brand-gold);
            opacity: 0.9 !important;
            border-radius: 80% 0 100% 0;
            pointer-events: none;
            z-index: 1000;
            animation: fall linear forwards;
            box-shadow: 0 0 5px rgba(201, 169, 106, 0.3);
        }

        @keyframes fall {
            0% { transform: translateY(0) rotate(0deg) translateX(0); opacity: 0; }
            10% { opacity: 0.9; }
            90% { opacity: 0.9; }
            100% { transform: translateY(110vh) rotate(540deg) translateX(30px); opacity: 0; }
        }

        .container {
            width: 100%;
            max-width: 480px;
            padding: 60px 20px;
            position: relative;
            z-index: 10;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        /* Hero / Header Section */
        .profile-container {
            text-align: center;
            margin-bottom: 50px;
            opacity: 0;
            transform: translateY(30px);
            animation: fadeInUp 1.2s cubic-bezier(0.23, 1, 0.32, 1) forwards;
        }

        .image-wrapper {
            position: relative;
            width: 130px;
            height: 130px;
            margin: 0 auto 28px;
        }

        .image-wrapper::before {
            content: '';
            position: absolute;
            inset: -12px;
            border: 1px solid var(--brand-gold);
            border-radius: 50%;
            opacity: 0.3;
            animation: orbit 15s linear infinite, pulse 3s ease-in-out infinite;
        }

        .image-wrapper::after {
            content: '';
            position: absolute;
            inset: -20px;
            border: 1px dashed var(--brand-gold);
            border-radius: 50%;
            opacity: 0.15;
            animation: orbit 25s linear infinite reverse;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); opacity: 0.3; }
            50% { transform: scale(1.05); opacity: 0.1; }
        }

        @keyframes orbit {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .profile-img {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            object-fit: cover;
            border: 4px solid #fff;
            box-shadow: 0 15px 45px rgba(31, 58, 46, 0.15);
            position: relative;
            z-index: 1;
        }

        .profile-name {
            font-family: 'Playfair Display', serif;
            font-size: 2.5rem;
            color: var(--brand-green);
            margin-bottom: 8px;
            letter-spacing: -0.03em;
            line-height: 1.1;
        }

        .profile-title {
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.3em;
            color: var(--brand-gold);
            font-weight: 700;
            margin-bottom: 20px;
            display: block;
        }

        .bio-container {
            position: relative;
            max-width: 340px;
            margin: 0 auto;
        }

        .profile-bio {
            font-size: 1.05rem;
            line-height: 1.6;
            color: var(--brand-dark);
            opacity: 0.8;
            font-style: italic;
            font-family: 'Playfair Display', serif;
        }

        /* Aesthetic Divider */
        .divider {
            width: 40px;
            height: 1px;
            background: var(--brand-gold);
            margin: 24px auto;
            opacity: 0.4;
        }

        /* Links Section - Editorial Style */
        .links-nav {
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .link-card {
            display: flex;
            align-items: center;
            text-decoration: none;
            padding: 24px 32px;
            background: #ffffff;
            border: 1px solid rgba(31, 58, 46, 0.08);
            border-radius: 20px;
            transition: all 0.5s cubic-bezier(0.19, 1, 0.22, 1);
            opacity: 0;
            transform: translateY(20px);
            position: relative;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(31, 58, 46, 0.03);
        }

        .link-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
            background: var(--brand-gold);
            transform: scaleY(0);
            transition: transform 0.4s ease;
            z-index: 2;
        }

        .link-card::after {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 50%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
            transform: skewX(-25deg);
        }

        .link-card:hover::after {
            animation: shimmer 1s ease forwards;
        }

        @keyframes shimmer {
            from { left: -100%; }
            to { left: 200%; }
        }

        .link-card:hover {
            transform: scale(1.03) translateY(-5px);
            background: rgba(255, 255, 255, 0.1);
            border-color: var(--brand-gold);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 0 0 30px rgba(201, 169, 106, 0.2);
        }

        .link-card:hover .link-label {
            color: var(--brand-gold);
            letter-spacing: 0.03em;
        }

        .link-card:hover::before {
            transform: scaleY(1);
        }

        .link-content {
            display: flex;
            flex-direction: column;
            text-align: left;
            flex: 1;
        }

        .link-label {
            font-size: 1.15rem;
            font-weight: 600;
            color: var(--brand-green);
            margin-bottom: 4px;
            font-family: 'Playfair Display', serif;
            transition: color 0.3s ease;
        }

        .link-sublabel {
            font-size: 0.85rem;
            color: var(--brand-green);
            opacity: 0.6;
            letter-spacing: 0.01em;
        }

        /* Floating Icon in Link */
        .link-arrow {
            color: var(--brand-gold);
            opacity: 0;
            transform: translateX(-10px);
            transition: all 0.4s ease;
        }

        .link-card:hover .link-arrow {
            opacity: 1;
            transform: translateX(0);
        }

        /* Entrance Animations Stagger */
        .link-card:nth-child(1) { animation: fadeInUp 1s ease 0.4s forwards; }
        .link-card:nth-child(2) { animation: fadeInUp 1s ease 0.6s forwards; }
        .link-card:nth-child(3) { animation: fadeInUp 1s ease 0.8s forwards; }

        @keyframes fadeInUp {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Editorial Info Cards */
        .info-grid {
            display: grid;
            grid-template-cols: 1fr 1fr;
            gap: 16px;
            width: 100%;
            margin-top: 40px;
            opacity: 0;
            animation: fadeIn 1.5s ease 1s forwards;
        }

        .info-item {
            background: #ffffff;
            border: 1px solid rgba(31, 58, 46, 0.08);
            padding: 16px;
            border-radius: 20px;
            text-align: center;
            box-shadow: 0 10px 30px rgba(31, 58, 46, 0.03);
        }

        .info-val {
            display: block;
            font-family: 'Playfair Display', serif;
            font-size: 1.2rem;
            color: var(--brand-green);
            font-weight: 600;
        }

        .info-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--brand-gold);
            font-weight: 600;
            opacity: 0.8;
        }

        /* Footer */
        .footer {
            margin-top: 80px;
            text-align: center;
            opacity: 0;
            animation: fadeIn 2s ease 1.5s forwards;
        }

        .footer p {
            font-size: 0.8rem;
            color: var(--brand-green);
            opacity: 0.5;
            letter-spacing: 0.15em;
            margin-bottom: 16px;
        }

        .alpha-logo {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.25em;
            color: var(--brand-gold);
            text-decoration: none;
            transition: all 0.3s;
        }

        .alpha-logo span:last-child {
            color: var(--brand-green);
        }

        .alpha-logo:hover {
            letter-spacing: 0.3em;
        }

        @keyframes fadeIn { to { opacity: 1; } }

        /* Mobile specific adjustments */
        @media (max-width: 480px) {
            .profile-name { font-size: 2.2rem; }
            .link-card { padding: 20px 24px; }
            .container { padding: 40px 20px; }
        }
    </style>
</head>
<body>
    <div class="main-wrapper" id="particle-host">
        <div class="background-blobs">
            <div class="blob blob-1"></div>
            <div class="blob blob-2"></div>
            <div class="blob blob-3"></div>
        </div>
        <div class="noise-texture"></div>


        <main class="container">
            <header class="profile-container">
                <div class="image-wrapper">
                    <img src="/professional/erika1.svg" alt="Erika Spinola" class="profile-img">
                </div>
                <span class="profile-title">Psicanalista Transpessoal</span>
                <h1 class="profile-name">Erika Spinola</h1>
                
                <div class="bio-container">
                    <div class="divider"></div>
                    <p class="profile-bio">
                        "O caminho do autoconhecimento é o retorno para casa."
                    </p>
                    <div class="divider"></div>
                </div>
            </header>

            <nav class="links-nav">
                <a href="https://wa.me/5571991951882" class="link-card">
                    <div class="link-content">
                        <span class="link-label">Inicie sua Jornada</span>
                        <span class="link-sublabel">Agende sua sessão individual pelo WhatsApp</span>
                    </div>
                    <div class="link-arrow">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                    </div>
                </a>

                <a href="/" class="link-card">
                    <div class="link-content">
                        <span class="link-label">Sobre o Método</span>
                        <span class="link-sublabel">Conheça a Psicanálise Transpessoal Sistêmica</span>
                    </div>
                    <div class="link-arrow">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                    </div>
                </a>

                <a href="https://wa.me/5571991951882" class="link-card">
                    <div class="link-content">
                        <span class="link-label">Agenda & Contato</span>
                        <span class="link-sublabel">Lauro de Freitas ou Atendimento Online</span>
                    </div>
                    <div class="link-arrow">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                    </div>
                </a>
            </nav>

            <div class="info-grid">
                <div class="info-item">
                    <span class="info-val">Lauro de Freitas - BA</span>
                    <span class="info-label">Presencial</span>
                </div>
                <div class="info-item">
                    <span class="info-val">Global</span>
                    <span class="info-label">Atendimento Online</span>
                </div>
            </div>

            <footer class="footer">
                <p>© 2026 ERIKA SPINOLA</p>
                <a href="https://www.sitesalphacode.com.br/solucoes/psicologos" class="alpha-logo">
                    DESENVOLVIDO POR <span>ALPHA CODE</span> ⚡
                </a>
            </footer>
        </main>
    </div>

    <script is:inline>
        function createParticle() {
            const host = document.getElementById('particle-host');
            if (!host) return;

            const p = document.createElement('div');
            p.className = 'particle';
            
            const size = Math.random() * 8 + 8;
            const duration = Math.random() * 5 + 6;
            // Spawning strictly between 5% and 85% to avoid horizontal scroll
            const left = 5 + (Math.random() * 80);
            
            p.style.width = size + 'px';
            p.style.height = size + 'px';
            p.style.left = left + '%';
            p.style.animationDuration = duration + 's';
            
            host.appendChild(p);
            
            setTimeout(() => {
                if (p.parentNode === host) {
                    host.removeChild(p);
                }
            }, duration * 1000);
        }
        
        function initEffect() {
            // Initial batch
            for(let i = 0; i < 15; i++) {
                setTimeout(createParticle, i * 300);
            }
            // Loop
            setInterval(createParticle, 1800);
        }

        // Multiple triggers to ensure it runs
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initEffect);
        } else {
            initEffect();
        }
    </script>
</body>
</html>
